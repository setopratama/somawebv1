                        href="#"
                        class="inline-flex items-center gap-4 rounded-full border border-white/10 bg-white/5 px-6 py-3 text-sm font-extrabold text-white/85 transition group-hover:bg-white/10"
                      >
                        Book a Call
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-white/10">
                          <svg viewBox="0 0 20 20" class="h-4 w-4">
                            <path
                              d="M7 5l6 5-6 5"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            />
                          </svg>
                        </span>
                      </a>
                    </div>
                  </div>
                </article>

                <article class="group relative overflow-hidden rounded-[28px] border border-white/10 bg-white/[0.03] p-8">
