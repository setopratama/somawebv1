                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.6"
                            opacity="0.9"
                          />
                          <circle cx="10" cy="14.2" r="0.9" fill="currentColor" />
                        </svg>
                      </div>
                    </div>

                    <h3 class="mt-10 text-center text-2xl font-extrabold tracking-tight text-white">Mobile App Development</h3>
                    <p class="mx-auto mt-5 max-w-md text-center text-sm leading-6 text-white/45">
                      With our Mobile App Development service, we harness the power of mobile technology to create
