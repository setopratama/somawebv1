                          <path
                            d="M5.5 3.5h9A2.5 2.5 0 0 1 17 6v8a2.5 2.5 0 0 1-2.5 2.5h-9A2.5 2.5 0 0 1 3 14V6a2.5 2.5 0 0 1 2.5-2.5Z"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.6"
                            opacity="0.9"
                          />
                        </svg>
                      </div>
                    </div>

                    <h3 class="mt-10 text-center text-2xl font-extrabold tracking-tight text-white">Web Development</h3>
                    <p class="mx-auto mt-5 max-w-md text-center text-sm leading-6 text-white/45">
                      Our Web Development service is focused on turning your website into a powerful digital asset. We utilize
                      the latest technologies and industry best practices to build dynamic and scalable websites that cater to
                      your business objectives.
                    </p>

                    <div class="mt-10 flex justify-center">
                      <a
                        href="#"
                        class="inline-flex items-center gap-4 rounded-full border border-white/10 bg-white/5 px-6 py-3 text-sm font-extrabold text-white/85 transition group-hover:bg-white/10"
                      >
                        Book a Call
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-white/10">
                          <svg viewBox="0 0 20 20" class="h-4 w-4">
                            <path
                              d="M7 5l6 5-6 5"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            />
                          </svg>
                        </span>
                      </a>
                    </div>
