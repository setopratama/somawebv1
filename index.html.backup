                            stroke="currentColor"
                            stroke-width="1.6"
                            stroke-linejoin="round"
                          />
                        </svg>
                      </div>
                    </div>

                    <h3 class="mt-10 text-center text-2xl font-extrabold tracking-tight text-white">Digital Marketing</h3>
                    <p class="mx-auto mt-5 max-w-md text-center text-sm leading-6 text-white/45">
                      In the digital age, marketing is a critical aspect of your business's success. Our Digital Marketing
                      service employs data-driven strategies to enhance your brand's visibility, attract targeted traffic, and
                      boost conversions.
                    </p>

                    <div class="mt-10 flex justify-center">
                      <a
                        href="#"
                        class="inline-flex items-center gap-4 rounded-full border border-white/10 bg-white/5 px-6 py-3 text-sm font-extrabold text-white/85 transition group-hover:bg-white/10"
                      >
                        Book a Call
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-white/10">
                          <svg viewBox="0 0 20 20" class="h-4 w-4">
                            <path
                              d="M7 5l6 5-6 5"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            />
                          </svg>
                        </span>
                      </a>
                    </div>
                  </div>
