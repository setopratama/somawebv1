                    <div class="absolute -left-14 -top-16 h-64 w-64 rounded-full bg-white/5 blur-2xl"></div>
                    <div class="absolute -right-14 -top-20 h-64 w-64 rounded-full bg-white/5 blur-2xl"></div>
                  </div>
                  <div class="relative">
                    <div class="flex items-center justify-center">
                      <div class="relative flex h-20 w-20 items-center justify-center rounded-full border border-white/10 bg-white/5">
                        <div class="absolute inset-0 rounded-full ring-1 ring-white/10"></div>
                        <div class="absolute inset-[-18px] rounded-full ring-1 ring-white/10"></div>
                        <div class="absolute inset-[-36px] rounded-full ring-1 ring-white/10"></div>
                        <svg viewBox="0 0 20 20" class="relative h-6 w-6 text-white/85">
                          <path
                            d="M7 4.5h6M7 15.5h6"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.6"
                            stroke-linecap="round"
                          />
                          <path
